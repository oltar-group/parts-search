# Server
HOST=127.0.0.1
PORT=3000

# UniqTrade API
UNIQTRADE_API_BASE_URL=https://order24-api.utr.ua
UNIQTRADE_WEB_BASE_URL=https://order24.utr.ua
UNIQTRADE_EMAIL=
UNIQTRADE_PASSWORD=
UNIQTRADE_BROWSER_FINGERPRINT=parts-search-prototype
UNIQTRADE_TIMEOUT_MS=20000

# S-LINE API
SLINE_API_BASE_URL=https://s-line.ua/api/v1
SLINE_WEB_BASE_URL=https://s-line.ua
SLINE_API_KEY=
SLINE_CURRENCY=UAH
SLINE_STORAGE_ID=
SLINE_SEND_BRAND_FLAG=false
SLINE_TIMEOUT_MS=20000

# Tehnomir API
TEHNOMIR_API_BASE_URL=https://api.tehnomir.com.ua
TEHNOMIR_WEB_BASE_URL=https://tehnomir.com.ua
TEHNOMIR_API_TOKEN=
TEHNOMIR_CURRENCY=UAH
TEHNOMIR_SHOW_ANALOGS=
TEHNOMIR_TIMEOUT_MS=20000

# Autonova-D API
AUTONOVA_API_BASE_URL=https://api.autonovad.ua/stable
AUTONOVA_AUTH_BASE_URL=https://api.autonovad.ua/stable
AUTONOVA_WEB_BASE_URL=https://autonovad.ua
AUTONOVA_LOGIN=
AUTONOVA_PASSWORD=
AUTONOVA_CLIENT_ID=
AUTONOVA_FILTER_BY_RESULT_CATEGORY=1,2,3
AUTONOVA_MAX_DETAILS=8
AUTONOVA_TIMEOUT_MS=20000

# OptionAuto / Vortex API
OPTIONAUTO_API_BASE_URL=https://crm.optionauto.com.ua/front_api
OPTIONAUTO_WEB_BASE_URL=https://www.optionauto.com.ua
OPTIONAUTO_API_KEY=
OPTIONAUTO_CLIENT_ID=
OPTIONAUTO_MAX_DETAILS=8
OPTIONAUTO_TIMEOUT_MS=20000

# Prototype behavior
INCLUDE_SUPPLIER_IMAGES=true
BUILD_VERSION=
BUILD_COMMIT=
BUILD_TIME=
SEARCH_LOG_LEVEL=summary
SEARCH_LOG_FILE=logs/search.log
SEARCH_LOG_MAX_BYTES=1048576
SEARCH_LOG_MAX_FILES=5
